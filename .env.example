# ── Site ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ────────────────────────────────────────────────────────
# Get these from https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the browser or commit to git.
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin seed account (used by scripts/seed-admin.ts) ─────────────
# Use a strong, unique password and change it after the first login.
ADMIN_EMAIL=
ADMIN_SEED_PASSWORD=

# ── Camel Build Assistant (Moonshot AI) ────────────────────────────
# Get your key from https://platform.moonshot.ai
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
MOONSHOT_MODEL=kimi-k2.6

# ── Bot protection (Cloudflare Turnstile, optional) ────────────────
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Email (optional) ────────────────────────────────────────────────
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=
ADMIN_ALERT_EMAIL=

# ── Maps + analytics (optional) ─────────────────────────────────────
NEXT_PUBLIC_MAP_PROVIDER_KEY=
ANALYTICS_ID=

# ── Google Analytics (GA4 measurement ID, e.g. G-XXXXXXXXXX) ───────
NEXT_PUBLIC_GA_ID=
